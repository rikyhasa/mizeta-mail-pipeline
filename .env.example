NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_COOKIE_NAME=mizeta_session
SESSION_TTL_HOURS=12

DATABASE_URL=postgresql://mizeta:mizeta_dev_only@localhost:5432/mizeta_mail_pipeline
DATABASE_URL_TEST=postgresql://mizeta:mizeta_dev_only@localhost:5432/mizeta_mail_pipeline_test

EMAIL_PROVIDER=mock
MICROSOFT365_CLIENT_ID=
MICROSOFT365_CLIENT_SECRET=
MICROSOFT365_TENANT_ID=
# Sync iniziale limitato e rinnovo subscription Graph (Fase 4, docs/email-integration.md)
MICROSOFT365_INITIAL_SYNC_LOOKBACK_DAYS=30
MICROSOFT365_INITIAL_SYNC_MAX_MESSAGES=200
MICROSOFT365_SUBSCRIPTION_RENEWAL_MARGIN_HOURS=24

# pec_imap resta uno scheletro documentato in questa fase (SPEC.md §3): queste variabili non
# sono usate da alcun codice, solo documentate per completezza.
PEC_IMAP_HOST=
PEC_IMAP_PORT=993
PEC_IMAP_USER=
PEC_IMAP_PASSWORD=

LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=

# Coda job su Postgres (Fase 4): retry con backoff esponenziale, dead-letter dopo JOB_MAX_ATTEMPTS.
# Il worker gira come processo separato: `npm run jobs:worker`.
JOB_POLL_INTERVAL_MS=5000
JOB_MAX_ATTEMPTS=6
JOB_BACKOFF_BASE_MS=60000
JOB_RECOVERY_INTERVAL_MINUTES=15

ATTACHMENT_STORAGE_DRIVER=local
ATTACHMENT_STORAGE_LOCAL_DIR=./storage

# Estrazione reale del testo degli allegati (Fase 10, docs/FASE-10-LETTURA-ALLEGATI.md):
# limiti tecnici, non regolabili dall'operatore. Il budget di spesa giornaliera per il
# livello 3 (visione) è invece in Impostazioni (RuleSettings.visionExtractionDailyBudgetUsd).
ATTACHMENT_EXTRACTION_MAX_SIZE_BYTES=20000000
ATTACHMENT_EXTRACTION_MAX_PAGES=20
ATTACHMENT_EXTRACTION_TIMEOUT_MS=30000
ATTACHMENT_TEXT_DENSITY_MIN_CHARS_PER_PAGE=40

# Registro MIT dispositivi di rilevamento velocità (Fase E, Tappa 5): "real" scarica davvero
# velox.mit.gov.it/dispositivi, "mock" legge fixture locali senza rete.
SPEED_REGISTRY_FETCHER=mock
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Local/demo only — never use in production
SEED_DEMO_PASSWORD=Password123!
