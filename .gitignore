# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local dev/build helpers
/.npm-cache-local
/storage

# eval artifact (docs/eval-report.md is the tracked human-readable snapshot)
/eval/report.json

# per-developer local Claude Code permissions
.claude/settings.local.json

# read-only clone of the Mizeta Flow UI reference (Fase 8 porting) — never commit
/.reference/

# FASE 8B/FASE 3: screenshot intermedi del ciclo visivo (scripts/ui-compare.ts), non
# versionati — solo la coppia finale in docs/screenshots/<schermata>/final/ viene committata,
# vedi docs/UI-PORTING-REPORT.md. Il dettaglio pratica (FASE 8B) è l'unica schermata ancora
# sulla struttura piatta storica /docs/screenshots/iter-*/.
/docs/screenshots/iter-*/
/docs/screenshots/*/iter-*/

